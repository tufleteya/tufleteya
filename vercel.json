{
  "framework": null,
  "buildCommand": "npm run build:prod",
  "outputDirectory": "www",
  "rewrites": [
    {
      "source": "/__/auth/:path*",
      "destination": "https://tufleteyarg.firebaseapp.com/__/auth/:path*"
    },
    {
      "source": "/__/firebase/:path*",
      "destination": "https://tufleteyarg.firebaseapp.com/__/firebase/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
